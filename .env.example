# Variables de entorno — copia este fichero a .env y ajusta los valores

# ─── MinIO (reemplaza Azure Blob Storage) ─────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_RAW=raw-reviews
MINIO_BUCKET_PROCESSED=processed-reviews

# ─── PostgreSQL (reemplaza Azure SQL Database) ────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=reviewsdb
POSTGRES_PORT=5432

# ─── Airflow (reemplaza Azure Data Factory) ───────────────────────────────────
# Credenciales de la UI de Airflow (creadas automáticamente por airflow-init)
AIRFLOW_USER=airflow
AIRFLOW_PASS=airflow
