{
    "name": "trigger_BlobNewFile",
    "type": "Microsoft.DataFactory/factories/triggers",
    "properties": {
        "description": "Storage Event Trigger: activa el pipeline cada vez que el consumer deposita un fichero .jsonl en 'raw-reviews'",
        "type": "BlobEventsTrigger",
        "typeProperties": {
            "blobPathBeginsWith": "/raw-reviews/blobs/batch_",
            "blobPathEndsWith": ".jsonl",
            "ignoreEmptyBlobs": true,
            "events": ["Microsoft.Storage.BlobCreated"],
            "scope": "/subscriptions/<subscription-id>/resourceGroups/<rg>/providers/Microsoft.Storage/storageAccounts/<account>"
        },
        "pipelines": [
            {
                "pipelineReference": {
                    "referenceName": "pipeline_reviews_etl",
                    "type": "PipelineReference"
                },
                "parameters": {
                    "blobFileName": "@triggerBody().fileName"
                }
            }
        ]
    }
}
